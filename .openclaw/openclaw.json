{
  "agent": {
    "name": "SecondBrainDaemon",
    "mode": "background",
    "interval_minutes": 30
  },
  "workspace": {
    "path": "/workspace",
    "heartbeat_file": "HEARTBEAT.md",
    "memory_file": "MEMORY.md"
  },
  "hooks": {
    "on_tick": "python3 /workspace/backend/query.py heartbeat",
    "on_compact": "python3 /workspace/backend/query.py compact"
  }
}
